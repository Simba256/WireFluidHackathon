# Deployer EOA — needs test WIRE from https://faucet.wirefluid.com
DEPLOYER_PRIVATE_KEY=0x

# Backend EOA that signs EIP-712 sync/claim vouchers.
# Used as PSLPoints.trustedSigner at construction.
SIGNER_ADDRESS=0x

# Optional RPC override (defaults to https://evm.wirefluid.com)
WIREFLUID_RPC_URL=https://evm.wirefluid.com

# wirefluidscan API key for verification (if required by explorer)
WIREFLUIDSCAN_API_KEY=

# Set to "true" to enable hardhat-gas-reporter in tests
REPORT_GAS=false
